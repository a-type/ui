{
	"name": "@a-type/ui",
	"version": "6.0.34",
	"type": "module",
	"repository": {
		"url": "https://github.com/a-type/ui"
	},
	"files": [
		"/dist",
		"/src"
	],
	"sideEffects": [
		".*\\.css$"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"node": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./arbor": {
			"types": "./dist/arbor/arbor.d.ts",
			"import": "./dist/arbor/arbor.js",
			"node": "./dist/arbor/arbor.js",
			"default": "./dist/arbor/arbor.js"
		},
		"./main.css": {
			"import": "./dist/css/main.css",
			"node": "./dist/css/main.css",
			"require": "./dist/css/main.css",
			"default": "./dist/css/main.css"
		}
	},
	"scripts": {
		"build:transpile": "tsc",
		"build:copy": "node --experimental-strip-types ./scripts/copy.ts",
		"build:arbor": "arbor build -o ./dist/css/arbor.css",
		"build": "pnpm run build:transpile && pnpm run build:copy && pnpm run build:arbor",
		"prepublish": "pnpm run build",
		"icons": "node ./scripts/generateIcons.js",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"up-radix": "pnpm update \"@radix-ui/*\" --latest",
		"bump": "pnpm run typecheck && bumpp",
		"test": "vitest",
		"test:unit": "vitest --project=unit",
		"test:snapshots": "pnpm build && vitest --project=snapshots",
		"test:arbor": "arbor validate ./src/**/*.css",
		"typecheck": "tsc --noEmit",
		"test:browser": "vitest --config=vitest.browser.config.ts",
		"lint": "eslint **/*.{ts,tsx} --fix",
		"prepare": "husky"
	},
	"peerDependencies": {
		"react": "^19",
		"react-dom": "^19"
	},
	"dependencies": {
		"@a-type/utils": "^1.1.9",
		"@arbor-css/core": "^0.0.135",
		"@arbor-css/postcss": "^0.0.135",
		"@base-ui/react": "^1.4.1",
		"@use-gesture/react": "^10.3.1",
		"browser-image-resizer": "^2.4.1",
		"calendar-blocks": "^0.4.0",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"formik": "^2.4.6",
		"frimousse": "^0.2.0",
		"motion": "^12.23.6",
		"pluralize": "^8.0.0",
		"valtio": "^2.1.4"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@storybook/addon-links": "10.4.0",
		"@storybook/react-vite": "10.4.0",
		"@testing-library/react": "^16.3.2",
		"@types/dom-chromium-installation-events": "^101.0.4",
		"@types/node": "^24.13.2",
		"@types/pluralize": "^0.0.33",
		"@types/react": "^19.0.1",
		"@types/react-dom": "^19.0.2",
		"@types/react-is": "^19.0.0",
		"@types/w3c-image-capture": "^1.0.10",
		"@types/web-app-manifest": "^1.0.9",
		"@vitejs/plugin-react": "^5.1.2",
		"@vitest/browser-playwright": "^4.0.18",
		"@vitest/ui": "4.0.18",
		"axios": "^1.5.0",
		"bumpp": "^10.3.1",
		"change-case": "^4.1.2",
		"dotenv": "^16.3.1",
		"eslint": "^9.39.2",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-storybook": "10.4.0",
		"fs-extra": "^11.1.1",
		"globals": "^17.0.0",
		"husky": "^9.1.7",
		"jiti": "^2.6.1",
		"lint-staged": "^16.2.7",
		"prettier": "^3.0.3",
		"react": "19.0.0",
		"react-dom": "19.0.0",
		"storybook": "10.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.53.0",
		"typescript-plugin-css-modules": "^5.2.0",
		"vitest": "^4.0.18",
		"vitest-browser-react": "^2.0.4"
	},
	"lint-staged": {
		"**/*.{ts,tsx}": [
			"prettier --write --cache",
			"eslint --fix --cache"
		]
	}
}
